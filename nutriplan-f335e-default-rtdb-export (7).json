    "-ORoyaKOxjeq5lRhw-8z": {
      "category": "breakfast",
      "createdAt": "2025-06-03T08:48:34.715Z",
      "description": "Bún bò Huế là món ăn đặc sản miền Trung, nổi bật với nước dùng đậm đà từ xương bò, sả và mắm ruốc, kết hợp với bún sợi to và thịt bò mềm thơm.",
      "imageUrl": "https://i2.ex-cdn.com/crystalbay.com/files/content/2024/08/15/bun-bo-hue-2-0933.jpg",
      "ingredients": [
        "Xương bò",
        "Chân giò heo",
        "Thịt bắp bò",
        "Bún sợi to",
        "Sả cây",
        "Mắm ruốc Huế",
        "Hành tím",
        "Ớt bột",
        "Dầu điều",
        "Rau thơm (giá, rau quế, bắp chuối)",
        "Muối, đường, nước mắm"
      ],
      "instructions": [
        "Hầm xương bò và chân giò để lấy nước dùng trong 2 giờ.",
        "Làm sạch và luộc sơ thịt bắp bò, chân giò.",
        "Xào sả, hành tím, ớt bột với dầu điều rồi cho vào nồi nước dùng.",
        "Thêm mắm ruốc đã hòa tan và lọc vào nồi nước.",
        "Nêm nếm nước dùng với muối, đường, nước mắm cho vừa miệng.",
        "Trụng bún, cho vào tô cùng thịt và rau sống.",
        "Chan nước dùng nóng lên, thêm hành lá và rau sống."
      ],
      "name": "Bún bò Huế",
      "nutrition": {
        "calories": 550,
        "carbs": 45,
        "fat": 22,
        "protein": 35
      },
      "updatedAt": "2025-06-03T08:48:34.715Z"
    },
    "-ORoz4_8tx5hJPFSGGPq": {
      "category": "breakfast",
      "createdAt": "2025-06-03T08:50:42.700Z",
      "description": "Bún riêu là món ăn dân dã nổi tiếng của miền Bắc Việt Nam với hương vị chua thanh, nước dùng ngọt từ cua đồng, kết hợp với riêu cua, đậu hũ chiên và cà chua.",
      "imageUrl": "https://i.ytimg.com/vi/C1P1Cw9J1-I/maxresdefault.jpg",
      "ingredients": [
        "Cua đồng",
        "Cà chua",
        "Đậu hũ chiên",
        "Hành tím",
        "Hành lá, rau răm",
        "Mắm tôm",
        "Bún tươi",
        "Nước mắm, muối, đường, hạt nêm",
        "Giấm bỗng (hoặc me chua)",
        "Trứng gà (tùy chọn để làm riêu cua đặc hơn)"
      ],
      "instructions": [
        "Làm sạch cua đồng, xay nhuyễn, lọc lấy nước cua.",
        "Bắc nồi nước cua lên bếp, đun nhỏ lửa đến khi riêu nổi lên.",
        "Xào cà chua với hành tím cho mềm rồi cho vào nồi nước cua.",
        "Nêm mắm tôm, muối, giấm bỗng cho vừa vị chua thanh.",
        "Cho đậu hũ chiên vào nồi, nấu thêm 5–10 phút.",
        "Trụng bún, cho vào tô cùng riêu, đậu hũ và nước dùng.",
        "Thêm hành lá, rau răm, ớt và dùng nóng với rau sống."
      ],
      "name": "Bún riêu",
      "nutrition": {
        "calories": 480,
        "carbs": 40,
        "fat": 20,
        "protein": 28
      },
      "updatedAt": "2025-06-03T08:50:42.700Z"
    },
    "-ORp02C_O-GmgpHJo8rq": {
      "category": "breakfast",
      "createdAt": "2025-06-03T08:59:17.304Z",
      "description": "Gỏi cuốn là món ăn nhẹ truyền thống của Việt Nam với bánh tráng cuốn tôm, thịt, bún và rau sống, ăn kèm nước chấm đậm đà như nước mắm chua ngọt hoặc tương đậu.",
      "imageUrl": "https://heyyofoods.com/wp-content/uploads/2024/03/3-4.jpg",
      "ingredients": [
        "Bánh tráng",
        "Tôm luộc bóc vỏ",
        "Thịt ba chỉ luộc",
        "Bún tươi",
        "Xà lách",
        "Rau thơm (rau mùi, húng quế)",
        "Hẹ hoặc lá hẹ",
        "Dưa leo cắt sợi",
        "Cà rốt cắt sợi",
        "Nước mắm, đường, tỏi, ớt (làm nước chấm)",
        "Tương đậu, đậu phộng (nếu chấm tương)"
      ],
      "instructions": [
        "Luộc tôm và thịt ba chỉ, thái lát mỏng.",
        "Rửa sạch rau sống, để ráo.",
        "Trụng bún tươi nếu cần, để nguội.",
        "Làm nước chấm: pha nước mắm chua ngọt hoặc tương đậu tùy khẩu vị.",
        "Nhúng bánh tráng qua nước cho mềm.",
        "Xếp lần lượt rau, bún, thịt, tôm, cuộn chặt tay.",
        "Dọn ra dĩa, ăn kèm với nước chấm."
      ],
      "name": "Gỏi cuốn",
      "nutrition": {
        "calories": 320,
        "carbs": 28,
        "fat": 12,
        "protein": 18
      },
      "updatedAt": "2025-06-03T08:59:17.304Z"
    },
    "-ORp0itNkETJQoPMsO1p": {
